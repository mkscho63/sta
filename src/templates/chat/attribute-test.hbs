<div class="sta roll chat card">
  {{speakername}} - {{flavor}}
  <div class="dice-roll collapsible">
    <div class="dice-result">
      <div class="dice-formula">
        <div class="dice-pool">{{dicePool}}d20{{withFocus}}{{withDedicatedFocus}}{{withDetermination}}</div>
        <div class="additional-info">
          <div class="target">{{localize "sta.roll.target"}}: {{checkTarget}}</div>
          <div class="range">{{localize "sta.roll.complicationrange"}}{{complicationMinimumValue}}+</div>
        </div>
      </div>
      <div class="tooltip">
        <section class="tooltip-part collapsible-content">
          <div class="dice">
            <ol class="dice-rolls">{{{diceString}}}</ol>
          </div>
        </section>
      </div>
      {{{complicationText}}}
      <h4 class="dice-total">{{successText}}</h4>
    </div>
  </div>
  <div class="reroll-button" data-message-id="{{_id}}">
    {{localize "sta.roll.rerollresults"}}
  </div>
</div>