<div class="sta roll chat card">
  {{speakerName}} - {{flavor}}
  <div class="dice-roll collapsible">
    <div class="dice-result">
      <div class="dice-formula">
        <div class="dice-pool">{{dicePool}}d6</div>
      </div>
      <div class="tooltip">
        <section class="tooltip-part collapsible-content">
          <div class="dice">
            <ol class="dice-rolls">{{{diceString}}}</ol>
          </div>
        </section>
      </div>
      <h4 class="dice-total">{{successText}}</h4>
      <h4 class="dice-total">{{{effectText}}}</h4>
    </div>
  </div>
  <div class="reroll-button" data-message-id="{{_id}}">
    {{localize "sta.roll.rerollresults"}}
  </div>
</div>